/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  
  # Cache Control par défaut
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Page d'accueil - cache court
/
  Cache-Control: public, max-age=1800, stale-while-revalidate=86400

# Articles - cache moyen
/articles/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=86400

# Static assets - cache très long (1 an)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Images - cache long (30 jours)
/*.png
  Cache-Control: public, max-age=2592000, immutable
  Access-Control-Allow-Origin: *
/*.jpg
  Cache-Control: public, max-age=2592000, immutable
  Access-Control-Allow-Origin: *
/*.jpeg
  Cache-Control: public, max-age=2592000, immutable
  Access-Control-Allow-Origin: *
/*.webp
  Cache-Control: public, max-age=2592000, immutable
  Access-Control-Allow-Origin: *

# SVG - cache long avec CORS
/*.svg
  Cache-Control: public, max-age=2592000, immutable
  Access-Control-Allow-Origin: *
  Content-Type: image/svg+xml

# Fonts - cache très long (1 an)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Sitemap et robots - cache court
/sitemap*.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml
/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain

# API routes - pas de cache
/api/*
  Cache-Control: no-store, max-age=0, private
  X-Robots-Tag: noindex
