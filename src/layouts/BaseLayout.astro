---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import { getAlternatePath, getLocaleFromPath, localeNames, ui, type Locale } from "../lib/i18n";
import { profile } from "../lib/profile";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
  locale?: Locale;
}

const {
  title,
  description,
  image = profile.canonicalImage,
  type = "website",
  publishedTime,
  modifiedTime,
  author = "Alain Paluku",
  keywords = profile.keywords,
  locale: explicitLocale,
} = Astro.props;

const locale = explicitLocale ?? getLocaleFromPath(Astro.url.pathname);
const t = ui[locale];
const alternateLocale: Locale = locale === "fr" ? "en" : "fr";
const alternateURL = new URL(getAlternatePath(Astro.url.pathname, alternateLocale), Astro.site);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageDescription = description ?? t.defaultDescription;
const siteTitle = t.siteTitle;
const fullTitle = `${title} | ${siteTitle}`;
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;

const personStructuredData = {
  "@type": "Person",
  "@id": `${Astro.site}#person`,
  name: profile.name,
  alternateName: ["ALAIN PALUK", "Alain Paluk"],
  jobTitle: locale === "fr" ? "Ingénieur Électricien" : "Electrical Engineer",
  description: pageDescription,
  url: Astro.site?.toString(),
  image,
  sameAs: profile.sameAs,
  knowsAbout: [
    "Alain Paluku",
    "ALAIN PALUK",
    "Réseaux électriques BT, MT, HT",
    "Énergies renouvelables",
    "Centrales hydrauliques",
    "Systèmes photovoltaïques",
    "Automatisme industriel",
    "Systèmes SCADA",
    "Maintenance prédictive",
    "IoT industriel",
    "Installations électriques industrielles",
    "Ingénierie électrique",
    "Electrical Engineering",
    "Smart Grid",
    "Efficacité énergétique",
  ],
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "Université Catholique la Sapientia",
  },
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    personStructuredData,
    type === "article"
      ? {
          "@type": "BlogPosting",
          headline: title,
          description: pageDescription,
          image,
          datePublished: publishedTime,
          dateModified: modifiedTime || publishedTime,
          author: { "@id": `${Astro.site}#person` },
          publisher: { "@id": `${Astro.site}#person` },
          mainEntityOfPage: canonicalURL.toString(),
          inLanguage: localeNames[locale],
        }
      : {
          "@type": "WebSite",
          name: siteTitle,
          url: Astro.site?.toString(),
          inLanguage: localeNames[locale],
          publisher: { "@id": `${Astro.site}#person` },
        },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={author} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="fr" href={new URL(getAlternatePath(Astro.url.pathname, "fr"), Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(getAlternatePath(Astro.url.pathname, "en"), Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(getAlternatePath(Astro.url.pathname, "fr"), Astro.site)} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content={locale === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:site_name" content={siteTitle} />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {type === "article" && author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={image} />

    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Structured Data for SEO/GEO -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="Alain Paluku" />
    <meta name="theme-color" content="#c0caf5" />

    <!-- Typography uses system fonts; third-party stylesheet and script providers are intentionally avoided. -->

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- SEO Verification Tags -->
    {googleVerification && (
      <meta name="google-site-verification" content={googleVerification} />
    )}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    <!-- Analytics intentionally omitted to avoid third-party scripts and improve privacy/performance. -->

    <!-- Theme Script -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- Critical CSS inline -->
    <style is:inline>
      :root {
        --color-background: 213 214 219;
        --color-foreground: 52 59 88;
        --color-muted-foreground: 85 90 120;
        --color-accent: 52 59 88;
      }
      .dark {
        --color-background: 26 27 38;
        --color-foreground: 192 202 245;
        --color-muted-foreground: 140 148 180;
        --color-accent: 192 202 245;
      }
      body {
        background-color: rgb(var(--color-background));
        color: rgb(var(--color-foreground));
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>

    <!-- PWA Service Worker - Chargement différé -->
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          setTimeout(() => {
            navigator.serviceWorker
              .register("/sw.js")
              .then((registration) => {
                console.log("Service Worker enregistré:", registration);
              })
              .catch((error) => {
                console.log("Erreur Service Worker:", error);
              });
          }, 2000);
        });
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <Header locale={locale} alternateURL={alternateURL.pathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <ScrollToTop />
  </body>
</html>
