---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
}

const {
  title,
  description = "Ingénieur Électricien spécialisé en réseaux électriques, énergies renouvelables et automatisme industriel. Expertise en dimensionnement de centrales hydrauliques et photovoltaïques, installations électriques industrielles et systèmes de monitoring.",
  image = "https://assets.alainpaluku.com/profil/alainpaluku.png",
  type = "website",
  publishedTime,
  modifiedTime,
  author = "Alain Paluku",
  keywords = [
    "ingénieur électricien",
    "réseaux électriques",
    "énergies renouvelables",
    "automatisme industriel",
    "SCADA",
    "maintenance prédictive",
    "centrales hydrauliques",
    "photovoltaïque",
  ],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = "Alain Paluku - Ingénieur Électricien";
const fullTitle = `${title} | ${siteTitle}`;
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;

const personStructuredData = {
  "@type": "Person",
  "@id": `${Astro.site}#person`,
  name: "Alain Paluku",
  jobTitle: "Ingénieur Électricien",
  description,
  url: Astro.site?.toString(),
  image,
  sameAs: [
    "https://linkedin.com/in/alainpaluku",
    "https://github.com/alainpaluku",
    "https://medium.com/@alainpaluku",
    "https://huggingface.co/alainpaluku",
  ],
  knowsAbout: [
    "Réseaux électriques BT, MT, HT",
    "Énergies renouvelables",
    "Centrales hydrauliques",
    "Systèmes photovoltaïques",
    "Automatisme industriel",
    "Systèmes SCADA",
    "Maintenance prédictive",
    "IoT industriel",
    "Installations électriques industrielles",
  ],
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "Université Catholique la Sapientia",
  },
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    personStructuredData,
    type === "article"
      ? {
          "@type": "BlogPosting",
          headline: title,
          description,
          image,
          datePublished: publishedTime,
          dateModified: modifiedTime || publishedTime,
          author: { "@id": `${Astro.site}#person` },
          publisher: { "@id": `${Astro.site}#person` },
          mainEntityOfPage: canonicalURL.toString(),
          inLanguage: "fr-FR",
        }
      : {
          "@type": "WebSite",
          name: siteTitle,
          url: Astro.site?.toString(),
          inLanguage: "fr-FR",
          publisher: { "@id": `${Astro.site}#person` },
        },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={author} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={siteTitle} />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {type === "article" && author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Structured Data for SEO/GEO -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="Alain Paluku" />
    <meta name="theme-color" content="#c0caf5" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://assets.alainpaluku.com" />

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Nunito:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- SEO Verification Tags -->
    {googleVerification && (
      <meta name="google-site-verification" content={googleVerification} />
    )}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    <!-- Google Analytics - optionnel via PUBLIC_GOOGLE_ANALYTICS_ID -->
    {
      googleAnalyticsId && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
          />
          <script is:inline define:vars={{ googleAnalyticsId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", googleAnalyticsId);
          </script>
        </>
      )
    }

    <!-- Theme Script -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- Critical CSS inline -->
    <style is:inline>
      :root {
        --color-background: 213 214 219;
        --color-foreground: 52 59 88;
        --color-muted-foreground: 85 90 120;
        --color-accent: 52 59 88;
      }
      .dark {
        --color-background: 26 27 38;
        --color-foreground: 192 202 245;
        --color-muted-foreground: 140 148 180;
        --color-accent: 192 202 245;
      }
      body {
        background-color: rgb(var(--color-background));
        color: rgb(var(--color-foreground));
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>

    <!-- PWA Service Worker - Chargement différé -->
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          setTimeout(() => {
            navigator.serviceWorker
              .register("/sw.js")
              .then((registration) => {
                console.log("Service Worker enregistré:", registration);
              })
              .catch((error) => {
                console.log("Erreur Service Worker:", error);
              });
          }, 2000);
        });
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>
