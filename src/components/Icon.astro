    console.warn(`Icon "${name}" not found`);
}
---

{
    icon && (
        <svg
            id={id}
            viewBox={icon.viewBox}
            fill={icon.fill || "none"}
            stroke={icon.stroke || undefined}
            stroke-width={icon.strokeWidth || undefined}
            stroke-linecap={icon.stroke ? "round" : undefined}
            stroke-linejoin={icon.stroke ? "round" : undefined}
            class={`${sizeClasses[size]} ${className}`}
        >
            <path d={icon.path} />
        </svg>
    )
}
