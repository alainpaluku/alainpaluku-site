---
import Icon from "./Icon.astro";
import { ui, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale].contact;

const contactMethods = [
  {
    name: "Email",
    value: "contact@alainpaluku.com",
    href: "mailto:contact@alainpaluku.com",
    icon: "email",
  },
  {
    name: "WhatsApp",
    value: "+243 897 023 743",
    href: "https://wa.me/243897023743",
    icon: "whatsapp",
  },
  {
    name: "Discord",
    value: "@alainpaluku",
    href: "https://discord.com/users/YOURID",
    icon: "discord",
  },
];

const socialLinks = [
  {
    name: "LinkedIn",
    href: "https://linkedin.com/in/alainpaluku",
    icon: "linkedin",
  },
  { name: "GitHub", href: "https://github.com/alainpaluku", icon: "github" },
  { name: "Medium", href: "https://medium.com/@alainpaluku", icon: "medium" },
  {
    name: "Hugging Face",
    href: "https://huggingface.co/alainpaluku",
    icon: "huggingface",
  },
];
---

<section class="py-16 sm:py-24">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
          {t.title}
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          {t.subtitle}
        </p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
      <div class="order-2 lg:order-1">
        <div class="bg-muted/20 border border-border rounded-xl p-6 sm:p-8">
          <h2 class="text-xl font-semibold text-foreground mb-6">
            {t.form.title}
          </h2>

          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-foreground mb-2">
                {t.form.nameLabel}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                maxlength="100"
                class="w-full px-4 py-3 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                placeholder={t.form.namePlaceholder}
              />
              <p id="name-error" class="text-xs text-red-500 mt-1 hidden"></p>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-foreground mb-2">
                {t.form.emailLabel}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                maxlength="100"
                class="w-full px-4 py-3 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                placeholder={t.form.emailPlaceholder}
              />
              <p id="email-error" class="text-xs text-red-500 mt-1 hidden"></p>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-foreground mb-2">
                {t.form.subjectLabel}
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                minlength="3"
                maxlength="200"
                class="w-full px-4 py-3 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                placeholder={t.form.subjectPlaceholder}
              />
              <p id="subject-error" class="text-xs text-red-500 mt-1 hidden"></p>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-foreground mb-2">
                {t.form.messageLabel}
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                minlength="10"
                maxlength="5000"
                class="w-full px-4 py-3 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all resize-none"
                placeholder={t.form.messagePlaceholder}
              ></textarea>
              <p id="message-error" class="text-xs text-red-500 mt-1 hidden"></p>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-3.5 bg-accent text-accent-foreground font-medium rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2 group disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span>{t.form.send}</span>
              <Icon name="arrow" size="md" class="group-hover:translate-x-1 transition-transform" />
            </button>

            <p id="form-status" class="text-sm hidden"></p>
          </form>
        </div>
      </div>

      <div class="order-1 lg:order-2 space-y-8">
        <div>
          <h2 class="text-xl font-semibold text-foreground mb-4">
            {t.directContact}
          </h2>
          <div class="space-y-3">
            {contactMethods.map((method) => (
              <a
                href={method.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 p-4 rounded-lg bg-muted/20 border border-border hover:border-accent/50 hover:bg-muted/30 transition-all"
              >
                <div class="flex-shrink-0 w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
                  <Icon name={method.icon} size="md" class="text-accent" />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-foreground text-sm">{method.name}</div>
                  <div class="text-sm text-muted-foreground truncate">{method.value}</div>
                </div>
                <Icon name="chevron" size="sm" class="text-muted-foreground group-hover:text-accent group-hover:translate-x-0.5 transition-all" />
              </a>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-foreground mb-4">
            {t.socialNetworks}
          </h2>
          <div class="grid grid-cols-2 gap-3">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 p-3 rounded-lg bg-muted/20 border border-border hover:border-accent/50 hover:bg-muted/30 transition-all"
              >
                <div class="flex-shrink-0 w-9 h-9 rounded-md bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
                  <Icon name={link.icon} size="sm" class="text-accent" />
                </div>
                <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">
                  {link.name}
                </span>
              </a>
            ))}
          </div>
        </div>

        <div class="p-6 rounded-xl bg-accent/5 border border-accent/20">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              <Icon name="info" size="md" class="text-accent" />
            </div>
            <div>
              <h3 class="font-medium text-foreground mb-1">{t.responseTimeTitle}</h3>
              <p class="text-sm text-muted-foreground">{t.responseTimeText}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<a
  href="https://wa.me/243897023743"
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-accent text-accent-foreground rounded-full flex items-center justify-center shadow-lg hover:scale-110 hover:shadow-xl transition-all duration-300"
  aria-label={locale === 'fr' ? 'Contacter via WhatsApp' : 'Contact via WhatsApp'}
>
  <Icon name="whatsapp" size="xl" />
</a>

<script>
  import { initializeWithAstro } from "../lib/client-utils";
  import { validateField, validateEmailField, showStatus, hideError } from "../lib/form-validation-ui";
  import { ui, getLocaleFromPath } from "../lib/i18n";

  initializeWithAstro(() => {
    const locale = getLocaleFromPath(window.location.pathname);
    const t = ui[locale].contact.form;
    const v = ui[locale].validation;

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const status = document.getElementById("form-status");
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    const nameInput = document.getElementById("name") as HTMLInputElement;
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const subjectInput = document.getElementById("subject") as HTMLInputElement;
    const messageInput = document.getElementById("message") as HTMLTextAreaElement;

    const nameError = document.getElementById("name-error");
    const emailError = document.getElementById("email-error");
    const subjectError = document.getElementById("subject-error");
    const messageError = document.getElementById("message-error");

    nameInput?.addEventListener("blur", () => validateField(nameInput, nameError, 2, 100, t.nameLabel, v));
    emailInput?.addEventListener("blur", () => validateEmailField(emailInput, emailError, v));
    subjectInput?.addEventListener("blur", () => validateField(subjectInput, subjectError, 3, 200, t.subjectLabel, v));
    messageInput?.addEventListener("blur", () => validateField(messageInput, messageError, 10, 5000, t.messageLabel, v));

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn || !status) return;

      const isNameValid = validateField(nameInput, nameError, 2, 100, t.nameLabel, v);
      const isEmailValid = validateEmailField(emailInput, emailError, v);
      const isSubjectValid = validateField(subjectInput, subjectError, 3, 200, t.subjectLabel, v);
      const isMessageValid = validateField(messageInput, messageError, 10, 5000, t.messageLabel, v);

      if (!isNameValid || !isEmailValid || !isSubjectValid || !isMessageValid) {
        showStatus(status, t.validationError, false);
        return;
      }

      const originalContent = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = `<span>${t.sending}</span>`;

      const formData = new FormData(form);
      const data = {
        name: formData.get("name"),
        email: formData.get("email"),
        subject: formData.get("subject"),
        message: formData.get("message"),
      };

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        const result = await response.json();
        if (response.ok) {
          showStatus(status, t.success, true);
          form.reset();
          hideError(nameInput, nameError);
          hideError(emailInput, emailError);
          hideError(subjectInput, subjectError);
          hideError(messageInput, messageError);
          setTimeout(() => { status.classList.add("hidden"); }, 5000);
        } else {
          const errorMessage = result.error || t.error;
          showStatus(status, `✗ ${errorMessage}`, false);
        }
      } catch (error) {
        showStatus(status, t.networkError, false);
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalContent;
      }
    });
  });
</script>
