---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
const { alternateURL, t } = Astro.props;
---
<div class="hidden md:flex items-center gap-8">
  <slot />
  <a href={alternateURL} class="flex items-center gap-1.5 text-muted-foreground hover:text-accent transition-colors" aria-label={t.languageLabel}>
    <Icon name="globe" size="lg" />
  </a>
  <ThemeToggle id="theme-toggle" />
</div>
