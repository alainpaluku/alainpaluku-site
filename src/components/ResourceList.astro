---
import ResourceIcon from "./ResourceIcon.astro";
import type { Resource } from "../lib/types";

interface Props {
    resources: Resource[];
}

const { resources } = Astro.props;
---

{
    resources && resources.length > 0 && (
        <div class="mt-12 p-6 rounded-xl bg-muted/30 border border-border">
            <h3 class="text-xl font-semibold text-foreground mb-4">
                Ressources
            </h3>
            <div class="space-y-3">
                {resources.map((resource) => (
                    <a
                        href={resource.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-start gap-3 p-3 rounded-lg bg-background border border-border hover:border-accent/50 transition-all group"
                    >
                        <div class="flex-shrink-0 mt-0.5">
                            <ResourceIcon type={resource.type} />
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">
                                {resource.title}
                            </p>
                            <p class="text-xs text-muted-foreground mt-0.5 truncate">
                                {resource.url}
                            </p>
                        </div>
                        <svg
                            class="w-4 h-4 text-muted-foreground group-hover:text-accent transition-colors flex-shrink-0 mt-1"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                            />
                        </svg>
                    </a>
                ))}
            </div>
        </div>
    )
}
