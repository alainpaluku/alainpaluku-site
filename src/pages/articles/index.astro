---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["Énergie", "Industrie", "Automatisme"];
const totalArticles = posts.length;
---

<BaseLayout
  title="ARTICLES"
  description="Articles techniques sur les réseaux électriques, énergies renouvelables et automatisme industriel. Analyses approfondies sur le dimensionnement de centrales, systèmes SCADA, protocoles industriels (Modbus RTU), IoT industriel et maintenance prédictive."
  keywords={[
    "articles ingénierie électrique",
    "réseaux électriques",
    "smart grids",
    "énergies renouvelables",
    "automatisme industriel",
    "SCADA",
    "Modbus RTU",
    "IoT industriel",
    "maintenance prédictive",
    "onduleurs photovoltaïques",
  ]}
>
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="mb-12">
          <h1
            class="text-3xl sm:text-4xl font-bold tracking-tight text-foreground mb-4"
          >
            ARTICLES
          </h1>
          <p class="text-lg text-muted-foreground max-w-2xl">
            Articles sur énergie, industrie, automatisme.
          </p>
        </div>

        <div class="mb-10 space-y-6">
          <div class="relative w-full">
            <input
              type="text"
              id="search-input"
              placeholder="Rechercher..."
              class="w-full px-5 py-3.5 pl-12 rounded-xl bg-muted/30 border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
            />
            <div
              class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="text-sm font-medium text-foreground">Catégories :</span
            >
            <div class="flex flex-wrap gap-2">
              {
                categories.map((category) => (
                  <button
                    data-category={category}
                    class="category-filter px-4 py-2 text-sm font-medium rounded-lg border border-border bg-muted/20 text-muted-foreground hover:border-accent hover:bg-accent/10 hover:text-accent transition-all"
                  >
                    {category}
                  </button>
                ))
              }
            </div>
            <button
              id="clear-filter"
              class="text-sm text-accent hover:underline hidden ml-2"
            >
              Effacer les filtres
            </button>
          </div>

          <div
            id="results-count"
            class="text-sm text-muted-foreground font-mono"
          >
            <span id="visible-count">{totalArticles}</span> article{
              totalArticles > 1 ? "s" : ""
            }
          </div>
        </div>

        <div id="articles-container" class="grid md:grid-cols-2 gap-6 mb-12">
          {
            posts.map((post) => (
              <div
                data-title={post.data.title.toLowerCase()}
                data-description={post.data.description.toLowerCase()}
                data-category={post.data.category.toLowerCase()}
                class="article-card"
              >
                <ArticleCard post={post} />
              </div>
            ))
          }
        </div>

        <div
          id="no-results"
          class="hidden text-center py-16 border border-dashed border-border rounded-xl"
        >
          <div
            class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-muted/30 mb-4"
          >
            <svg
              class="w-8 h-8 text-muted-foreground"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <p class="text-lg font-medium text-foreground mb-2">
            Aucun article trouvé
          </p>
          <p class="text-sm text-muted-foreground">
            Essayez de modifier vos critères de recherche
          </p>
        </div>

        {
          posts.length === 0 && (
            <div class="text-center py-16 border border-dashed border-border rounded-xl">
              <p class="font-mono text-sm text-muted-foreground">
                // Articles à venir
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <script>
    import { createFilterSystem } from "../../lib/filter-utils";

    createFilterSystem(
      "search-input",
      "articles-container",
      ".article-card",
      ".category-filter",
      "clear-filter",
      "visible-count",
      "no-results",
      "data-category",
    );
  </script>
</BaseLayout>
