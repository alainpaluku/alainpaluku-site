---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Button from "../components/Button.astro";

const articles = (await getCollection("blog"))
  .filter((article) => !article.data.draft)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);
---

<BaseLayout
  title="ACCUEIL"
  description="Alain Paluku - Ingénieur Électricien spécialisé en réseaux électriques, énergies renouvelables et automatisme industriel. Expertise en dimensionnement de centrales hydrauliques et photovoltaïques, installations électriques industrielles, systèmes SCADA et maintenance prédictive."
  keywords={[
    "ingénieur électricien",
    "réseaux électriques",
    "énergies renouvelables",
    "automatisme industriel",
    "centrale hydraulique",
    "photovoltaïque",
    "SCADA",
    "maintenance prédictive",
    "IoT industriel",
    "installation électrique industrielle",
  ]}
>
  <!-- Hero Section -->
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <!-- Terminal intro -->
        <div class="mb-8 text-center"></div>

        <!-- Profile Section with Image and CTA -->
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <!-- Left: CTA and Description -->
          <div class="order-2 lg:order-1 flex flex-col justify-center">
            <h1
              class="text-4xl sm:text-5xl md:text-6xl font-bold text-foreground mb-4 tracking-tight uppercase"
            >
              Alain Paluku
            </h1>

            <h2
              class="text-lg sm:text-xl md:text-2xl text-muted-foreground mb-8 uppercase tracking-wider"
            >
              Ingénieur Électricien | Développeur Système Embarqué
            </h2>

            <div class="flex flex-col sm:flex-row gap-4">
              <Button
                href="/contact/"
                variant="primary"
                icon="arrow"
                class="px-8 py-4"
              >
                Me contacter
              </Button>
              <Button href="/a-propos/" variant="secondary" class="px-8 py-4">
                En savoir plus
              </Button>
            </div>

            <SocialLinks
              variant="compact"
              class="mt-6 justify-center sm:justify-start"
            />
          </div>

          <!-- Right: Image with gradient -->
          <div class="order-1 lg:order-2 flex justify-center">
            <img
              src="https://assets.alainpaluku.com/profil/alainpaluku.png"
              alt="Alain Paluku - Ingénieur Électricien spécialisé en réseaux électriques et automatisme"
              width="224"
              height="300"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-48 h-auto sm:w-56 sm:h-auto"
              style="mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Section -->
  <section class="py-16 sm:py-20 border-t border-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <h2
          class="text-2xl sm:text-3xl font-semibold text-foreground mb-8 sm:mb-12"
        >
          Articles récents
        </h2>

        {
          articles.length > 0 ? (
            <>
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {articles.map((post) => <ArticleCard post={post} />)}
              </div>

              <div class="mt-8 text-center">
                <Button href="/articles/" variant="secondary" icon="arrow">
                  Voir plus
                </Button>
              </div>
            </>
          ) : (
            <div class="text-center py-12 border border-dashed border-border rounded-xl">
              <p class="font-mono text-sm text-muted-foreground mb-2">
                // Articles techniques en préparation
              </p>
              <p class="text-sm text-muted-foreground">
                Revenez bientôt pour lire les publications sur l'énergie, l'industrie et l'automatisme.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
