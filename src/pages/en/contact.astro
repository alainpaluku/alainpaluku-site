---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { CONTACT_LINKS, SOCIAL_LINKS } from '../../lib/constants';
import { profile } from '../../lib/profile';
import { ui } from '../../lib/i18n';
---

<BaseLayout title="CONTACT" locale="en" description={ui.en.defaultDescription} keywords={profile.keywords}>
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl sm:text-5xl font-bold text-foreground mb-4 font-serif">Contact Alain Paluku</h1>
        <p class="text-muted-foreground mb-8">
          Discuss an electrical network, renewable energy, embedded systems or industrial automation project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          {CONTACT_LINKS.map((link) => (
            <Button href={link.href} variant="primary" class="px-8 py-4">{link.label}</Button>
          ))}
        </div>
        <div class="flex flex-wrap gap-4 justify-center">
          {SOCIAL_LINKS.map((link) => (
            <a class="text-sm text-muted-foreground hover:text-accent" href={link.href} target="_blank" rel="noopener noreferrer">{link.name}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
