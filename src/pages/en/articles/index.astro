---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { profile } from '../../../lib/profile';
import { ui } from '../../../lib/i18n';

const articles = (await getCollection('blog'))
  .filter((article) => !article.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="ARTICLES" locale="en" description={ui.en.defaultDescription} keywords={profile.keywords}>
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <h1 class="text-3xl sm:text-5xl font-bold text-foreground mb-4 font-serif">Articles</h1>
        <p class="text-muted-foreground mb-10">Technical publications by Alain Paluku about energy, industry and automation.</p>
        {articles.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {articles.map((post) => <ArticleCard post={post} />)}
          </div>
        ) : (
          <div class="text-center py-12 border border-dashed border-border rounded-xl text-muted-foreground">
            Technical articles are in preparation.
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
